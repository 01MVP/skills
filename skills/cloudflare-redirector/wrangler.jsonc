{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cf-bulk-redirector",
	"account_id": "YOUR_ACCOUNT_ID",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-11",
	"routes": [
		{
			"pattern": "docs.example.com/*",
			"zone_name": "example.com"
		}
	],
	"observability": {
		"enabled": true
	}
}
